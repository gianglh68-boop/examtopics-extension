{
  "manifest_version": 3,
  "name": "ExamTopics Popup Killer",
  "version": "1.2.1",
  "description": "Tắt popup, Prev/Next, lưu câu hỏi vào bank theo mã đề và auto-loop autosave hàng loạt trên examtopics.com",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.examtopics.com/*"
      ],
      "js": ["content.js"],
      "css": ["block.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "ExamTopics Popup Killer (đang hoạt động)"
  }
}
