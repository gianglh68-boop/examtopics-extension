{
  "manifest_version": 3,
  "name": "ExamTopics Popup Killer",
  "version": "1.1.0",
  "description": "Tắt popup chặn nội dung, điều hướng Prev/Next và lưu câu hỏi vào bank theo mã đề trên examtopics.com",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.examtopics.com/*"
      ],
      "js": ["content.js"],
      "css": ["block.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "ExamTopics Popup Killer (đang hoạt động)"
  }
}
